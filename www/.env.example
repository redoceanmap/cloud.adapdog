# API 서버 주소 (FastAPI adapdog 백엔드)
VITE_API_BASE_URL=http://localhost:8000/api

# false로 설정하면 백엔드 API 사용 (권장). true면 프론트 로컬 Mock만 사용
# 장소: backend/csv → ingest_facilities.py → Postgres → /map/pet-place/search
# 반려견: 회원가입·등록 → Neon DB pet 테이블 → /users/pet/me
VITE_USE_MOCK=false

# OpenWeatherMap (https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key

# ── 네이버 지도 (Web Dynamic Map) ──────────────────────────────
# 1. 네이버 클라우드 → AI·NAVER API → Application 등록
# 2. 서비스: "Web Dynamic Map" 선택
# 3. Web 서비스 URL 등록 (공식 가이드: 포트 없이 등록)
#    - http://localhost
#    - http://127.0.0.1
#    (안 되면 http://localhost:5173 도 추가 시도)
# 4. [인증 정보]의 Client ID를 아래에 입력
# 5. npm run dev 재시작 필수 (VITE_ 변수는 빌드/시작 시 주입)
#
# Client Secret(NAVER_CLIENT_SECRET)은 브라우저에 넣지 마세요!
VITE_NAVER_MAP_CLIENT_ID=your_naver_client_id

# ncpKeyId(기본) 또는 ncpClientId — 둘 다 자동 시도하지만, 명시 가능
# VITE_NAVER_MAP_KEY_TYPE=ncpKeyId
