# 발자국 FastAPI 백엔드 (cloud.adapdog/adapdog, 포트 8000)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── 네이버 지도 (Web Dynamic Map) ──────────────────────────────
# developers.naver.com 검색 API(NAVER_CLIENT_ID)와 다른 키입니다.
# 1. 네이버 클라우드 → AI·NAVER API → Application 등록
# 2. 서비스: "Web Dynamic Map" 선택
# 3. Web 서비스 URL (포트·경로 없이):
#    - http://localhost
#    - http://127.0.0.1
# 4. [인증 정보]의 Client ID(ncpKeyId)를 아래에 입력
# 5. npm run dev 재시작 필수
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
# NEXT_PUBLIC_NAVER_MAP_KEY_TYPE=ncpKeyId
