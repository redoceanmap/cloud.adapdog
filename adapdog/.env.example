# adapdog 환경변수 예시 — 복사해서 .env 로 채워 사용 (.env 는 커밋 금지).
# 비워두면 각 기능이 목(mock)/규칙기반/폴백으로 자동 동작한다.

# ── 3NF DB (Neon serverless Postgres 권장) ───────────────────────────
# 드라이버는 postgresql+psycopg 사용. Neon이면 ?sslmode=require&channel_binding=require 유지.
# 미설정 시 DB 없이 목 데이터로 부팅.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# ── Gemini 동선/정책카드 에이전트 ────────────────────────────────────
# 미설정 시 규칙기반 폴백으로 자동 동작.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# ── data.go.kr 일반 인증키(Decoding) ─────────────────────────────────
# 인제스트의 API 적재 + 기상청 키 미지정 시 재사용.
DATA_GO_KR_SERVICE_KEY=your-data-go-kr-key-here

# ── 기상청 단기예보 조회서비스 (data.go.kr 15084084, 별도 활용신청) ──
# KMA_SERVICE_KEY 미지정 시 DATA_GO_KR_SERVICE_KEY 를 재사용.
# KMA_WEATHER_ENDPOINT=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getUltraSrtNcst
# KMA_SERVICE_KEY=your-kma-key-here

# ── 반려동물 동반 문화시설 odcloud API (data.go.kr 15111389, 선택) ────
# DB가 1순위라 보통 미설정. 둘 다 채우면 DB 없을 때 실 API 폴백.
# PETPLACE_API_ENDPOINT=https://api.odcloud.kr/api/15111389/v1/uddi:xxxxxxxx
# PETPLACE_API_SERVICE_KEY=your-data-go-kr-key-here
# PETPLACE_API_MAX_ROWS=3000

# ── 전국길관광정보 CSV 경로 (선택, 기본값은 ../csv/ 자동탐색) ─────────
# TRAIL_CSV_PATH=/abs/path/to/전국길관광정보표준데이터.csv
